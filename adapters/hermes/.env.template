# Hermes/Sotto secrets. Copy to ~/.hermes/.env
# This IS Hermes' native model key (Hermes manages providers/keys) — not a separate Sotto store.
# The brief needs a 1M-CONTEXT model; Gemini 3.6 Flash recommended. Any 1M model works.
GOOGLE_AI_API_KEY=<your-gemini-key>           # 1M-ctx model for the brief (+ chat, if you set it as the model)
SOTTO_DATA=/data                              # exhaust volume path (passed to the skill scripts)
SOTTO_TRIGGER_TOKEN=<bearer-for-/sotto/trigger>   # shared with the Bridge at pairing
# No Claude key (no polish stage). No Google/Granola OAuth secrets here — Hermes owns those.
